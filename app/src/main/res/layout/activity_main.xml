<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:paddingTop="48dp"
    android:paddingBottom="16dp">

    <!-- Botones cambiar canción ARRIBA -->
    <LinearLayout
        android:id="@+id/controlsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnPrevious"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:background="@drawable/bg_circle_green_light"
            android:padding="22dp"
            android:src="@drawable/ic_skip_previous"
            android:tint="@color/bg_dark" />

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/bg_circle_accent"
            android:padding="22dp"
            android:src="@drawable/ic_play"
            android:tint="@color/bg_dark" />

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:background="@drawable/bg_circle_green_light"
            android:padding="22dp"
            android:src="@drawable/ic_skip_next"
            android:tint="@color/bg_dark" />

    </LinearLayout>

    <!-- Volumen -->
    <LinearLayout
        android:id="@+id/volumeRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/controlsRow">

        <ImageButton
            android:id="@+id/btnVolumeDown"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:background="@drawable/bg_circle_blue_light"
            android:padding="22dp"
            android:src="@drawable/ic_volume_down"
            android:tint="@color/bg_dark" />

        <SeekBar
            android:id="@+id/volumeSlider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent"
            android:progressBackgroundTint="@color/bg_surface" />

        <ImageButton
            android:id="@+id/btnVolumeUp"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:background="@drawable/bg_circle_blue_light"
            android:padding="22dp"
            android:src="@drawable/ic_volume_up"
            android:tint="@color/bg_dark" />

    </LinearLayout>

    <!-- Título y artista -->
    <TextView
        android:id="@+id/tvSongTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="14dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:marqueeRepeatLimit="marquee_forever"
        android:scrollHorizontally="true"
        android:singleLine="true"
        android:text="Sin música activa"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/volumeRow" />

    <TextView
        android:id="@+id/tvArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="4dp"
        android:singleLine="true"
        android:ellipsize="end"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSongTitle" />

    <!-- Progreso -->
    <SeekBar
        android:id="@+id/progressBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="10dp"
        android:progressTint="@color/accent"
        android:thumbTint="@color/accent"
        android:progressBackgroundTint="@color/bg_surface"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvArtist" />

    <TextView
        android:id="@+id/tvCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="2dp"
        android:text="0:00"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressBar" />

    <TextView
        android:id="@+id/tvTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="2dp"
        android:text="0:00"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressBar" />

    <!-- Stats: pulso, velocidad y hora -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCurrentTime">

        <TextView
            android:id="@+id/tvHeartRate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="❤️ -- bpm"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🚴 -- km/h"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🕐 --:--"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Preview de cámara con botón encender/apagar -->
    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@color/bg_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsRow">

        <SurfaceView
            android:id="@+id/cameraPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="invisible" />

        <!-- Botón pequeño encender/apagar cámara -->
        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/bg_circle_semi"
            android:padding="10dp"
            android:src="@drawable/ic_camera_on"
            android:tint="#FFFFFF" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
